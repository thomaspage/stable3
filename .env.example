# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — never commit real tokens.

# Mapbox public access token (https://account.mapbox.com/access-tokens/)
REACT_APP_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Contentful Content Delivery API token (https://app.contentful.com/ → Settings → API keys)
REACT_APP_CONTENTFUL_TOKEN=your_contentful_cda_token_here

# Contentful space ID and environment (usually "master")
REACT_APP_CONTENTFUL_SPACE_ID=your_space_id_here
REACT_APP_CONTENTFUL_ENVIRONMENT=master
